// ApplyWise — Prisma Schema
// Updated: 2026-04-22
// Architecture: shared program library + personal user layer
//
// ProgramIntelligence = shared program library (all users see this)
// UserApplication = personal layer (user's relationship to a program)
// Old School/Program tables kept but deprecated — no new code should reference them

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id              String    @id
  email           String    @unique
  name            String?
  avatarUrl       String?
  language        String    @default("zh")
  appsData        Json?     @default("[]") // DEPRECATED — use UserApplication table
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  profile         StudentProfile?
  applications    UserApplication[]
  atoms           Atom[]
  conversations   Conversation[]
}

model StudentProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  undergradSchool     String?
  undergradMajor      String?
  gpa                 Float?
  gpaScale            Float?    @default(4.0)
  toeflScore          Int?
  greVerbal           Int?
  greQuant            Int?
  greWriting          Float?

  targetDegree        String?   @default("MS")
  targetFields        String[]
  careerGoal          String?
  preferredRegions    String[]
  budgetRangeCny      Int?
  targetYear          Int?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================================
// SHARED PROGRAM LIBRARY
// One extraction serves all users. Grows organically.
// ============================================================

model ProgramIntelligence {
  id              String    @id @default(cuid())

  // Searchable identity (indexed for fast lookup)
  schoolSlug      String                          // "mit" — for cache key
  programSlug     String                          // "master-of-finance" — for cache key
  cycle           String                          // "2027" — application cycle

  // Human-readable names (for search + display)
  schoolName      String                          // "Massachusetts Institute of Technology"
  schoolNameZh    String?                         // "麻省理工学院"
  programName     String                          // "Master of Finance (MFin)"
  programNameZh   String?                         // "金融硕士"
  degree          String?                         // "MFin"
  field           String?                         // "finance"

  // Full extraction data — the complete ExtractedProgram object
  data            Json                            // everything Claude extracted
  confidence      Float     @default(0)           // 0-1
  warnings        Json      @default("[]")        // validation warnings
  sourceUrls      Json      @default("[]")        // all crawled page URLs

  // Extraction metadata
  inputUrl        String?                         // the URL user originally pasted
  extractedAt     DateTime  @default(now())       // when extraction ran
  crawlDuration   Int?                            // milliseconds

  // Layer 2: community wisdom (future)
  enrichedData    Json?
  enrichedAt      DateTime?

  // Freshness
  pageHash        String?                         // detect if .edu page changed

  // Meta
  isDeleted       Boolean   @default(false)
  createdAt       DateTime  @default(now())  @map("created_at")
  updatedAt       DateTime  @updatedAt       @map("updated_at")

  // Relations
  applications    UserApplication[]

  @@unique([schoolSlug, programSlug, cycle])
  @@index([schoolName, programName])             // for text search
  @@index([field])                                // filter by field
  @@map("program_intelligence")
}

// ============================================================
// USER'S APPLICATIONS (personal layer)
// Links a user to a program. Stores only user-specific data.
// ============================================================

model UserApplication {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  programIntelligenceId String
  program               ProgramIntelligence @relation(fields: [programIntelligenceId], references: [id])

  // User's relationship to this program
  tier            String    @default("target")    // "reach", "target", "safe"
  status          String    @default("not_started")
  // Statuses: not_started → in_progress → materials_ready →
  //           submitted → under_review → interview →
  //           accepted / rejected / waitlisted

  // Task state — JSON blob for flexibility
  tasksState      Json      @default("{}")

  // User's notes and outcomes
  notes           String?   @db.Text
  submittedAt     DateTime?
  decisionAt      DateTime?
  result          String?                         // "accepted", "rejected", "waitlisted"
  scholarshipInfo String?

  addedAt         DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, programIntelligenceId])
}

// ============================================================
// MATERIAL VAULT — ATOMS
// ============================================================

model Atom {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  content         String    @db.Text
  summary         String?
  contentEn       String?   @db.Text

  category        String
  abilityTags     String[]
  qualityTags     String[]
  keywords        String[]

  source          String    @default("manual")
  sourceId        String?
  timeframe       String?

  linkedPrograms  String[]
  linkedEssays    String[]

  dimensionScores Json?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([userId, category])
}

// ============================================================
// AI CONVERSATIONS
// ============================================================

model Conversation {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type            String
  title           String?
  summary         String?   @db.Text
  atomsExtracted  Int       @default(0)

  messages        Message[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Message {
  id              String    @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role            String
  content         String    @db.Text
  metadata        Json?

  createdAt       DateTime  @default(now())
}

// ============================================================
// DEPRECATED — kept for reference, do not use in new code
// ============================================================

model School {
  id              String    @id @default(cuid())
  name            String
  nameZh          String?
  shortName       String?
  location        String?
  region          String?
  ranking         Int?
  websiteUrl      String?
  logoUrl         String?
  toeflCode       String?
  greCode         String?

  programs        Program[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Program {
  id              String    @id @default(cuid())
  schoolId        String
  school          School    @relation(fields: [schoolId], references: [id])

  name            String
  nameZh          String?
  department      String?
  degree          String
  field           String
  duration        String?
  totalCredits    Int?
  costPerCredit   Float?
  estimatedTotal  Float?
  livingCostMonth Float?

  toeflMin        Int?
  toeflMedian     Int?
  greRequired     Boolean   @default(false)
  greMin          Int?
  applicationFee  Float?
  deadlineEarly   DateTime?
  deadlineRegular DateTime?
  deadlineFinal   DateTime?
  wesRequired     Boolean   @default(false)
  wesEvalType     String?
  recsRequired    Int?      @default(3)
  recsAcademicMin Int?      @default(2)
  interviewFormat String?

  programUrl      String?
  portalUrl       String?
  essayPrompts    Json?
  requiredDocs    String[]

  rawContent      String?   @db.Text
  lastScrapedAt   DateTime?
  isAutoVerified  Boolean   @default(false)
  sourceHash      String?
  verifiedAt      DateTime?
  sourceUrl       String?
  notes           String?   @db.Text

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
